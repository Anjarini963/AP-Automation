# ---------------------------------------------------------------------------
# AP Automation — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# ---------- Anthropic / Claude ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-7

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ap_automation
POSTGRES_USER=ap_user
POSTGRES_PASSWORD=change-me
# Full SQLAlchemy URL (used by FastAPI). Keep in sync with the values above.
DATABASE_URL=postgresql+psycopg://ap_user:change-me@localhost:5432/ap_automation

# ---------- n8n ----------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
# 32+ char random string used to encrypt stored credentials in n8n
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string
# Public URL n8n uses for webhooks (set to your VPS URL in production)
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Riyadh

# ---------- Gmail (IMAP + SMTP, app password) ----------
GMAIL_ADDRESS=your-test-inbox@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ---------- Slack ----------
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-x-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APPROVALS_CHANNEL_ID=C0XXXXXXXXX

# ---------- Telegram (optional system pings) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- FastAPI ----------
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_LOG_LEVEL=info
# Comma-separated origins allowed to call the API (n8n and dashboard hosts)
FASTAPI_CORS_ORIGINS=http://localhost:5678,http://localhost:8501
# Base URL n8n / dashboard use to reach FastAPI
FASTAPI_BASE_URL=http://localhost:8000

# ---------- Streamlit dashboard ----------
STREAMLIT_PORT=8501
